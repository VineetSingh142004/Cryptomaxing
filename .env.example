# Application
NODE_ENV=development
APP_NAME=Alpha Autopilot
APP_URL=http://localhost:3000

# Database — Supabase direct connection (encode special chars in password, e.g. @ → %40)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?schema=public&sslmode=require

# Redis (placeholder — not required for Prompt 1)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Security — ENCRYPTION_KEY (required before storing real API keys in vault)
# Format: base64 string decoding to 32+ bytes
# Generate (macOS/Linux):  openssl rand -base64 32
# Generate (PowerShell):   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])
# Never commit this value. Never expose to the frontend.
# Leave empty for local dev — vault writes BLOCKED until set; production refuses unsafe encryption.
ENCRYPTION_KEY=
