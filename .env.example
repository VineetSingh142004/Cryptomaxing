# Application
NODE_ENV=development
APP_NAME=Alpha Autopilot
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alpha_autopilot?schema=public

# Redis (placeholder — not required for Prompt 1)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Security (generate with: openssl rand -base64 32)
# Required for production. Dev encryption is UNSAFE without this.
ENCRYPTION_KEY=
