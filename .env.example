# Application

NODE_ENV=development

APP_NAME=Alpha Autopilot

APP_URL=http://localhost:3000



# Personal local use — single owner, no login required

APP_MODE=local

LOCAL_OWNER_MODE=true



# Database — Supabase PostgreSQL (encode special chars in password, e.g. @ → %40)

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?schema=public&sslmode=require

DIRECT_URL=



# Redis (placeholder — not required)

REDIS_URL=redis://localhost:6379



# Logging

LOG_LEVEL=info



# Supabase Auth — OPTIONAL in local owner mode; required before deployment/multi-user use

NEXT_PUBLIC_SUPABASE_URL=

NEXT_PUBLIC_SUPABASE_ANON_KEY=



# Security — ENCRYPTION_KEY (required before storing real API keys in vault)

# Format: base64 string decoding to exactly 32 bytes

# Generate (PowerShell):

#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])

# Generate (OpenSSL):

#   openssl rand -base64 32

# Never commit this value. Never expose to the frontend.

ENCRYPTION_KEY=



# Market data provider — kraken uses public API when wired

MARKET_DATA_PROVIDER=kraken



# WARNING:

# - Do not expose this app publicly in local owner mode.

# - Use Supabase Auth before deployment.

# - ENCRYPTION_KEY is still required for storing API keys.

# - Never commit real secrets to git.

