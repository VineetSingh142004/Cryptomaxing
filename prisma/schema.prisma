generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity & Accounts ───────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exchangeAccounts ExchangeAccount[]
  modeState        ModeState?
  auditLogs        AuditLog[]
  alerts           Alert[]
  providerCredentials ProviderCredential[]
  paperEvidenceRuns PaperEvidenceRun[]
  paperSignals      PaperSignal[]
  paperForwardTrades PaperTrade[]

  @@map("users")
}

model ExchangeAccount {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  label     String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue           Venue             @relation(fields: [venueId], references: [id])
  encryptedApiKey EncryptedApiKey?
  permissions     ApiKeyPermission[]
  orders          Order[]
  positions       Position[]
  paperOrders     PaperOrder[]

  @@index([userId])
  @@index([venueId])
  @@map("exchange_accounts")
}

model EncryptedApiKey {
  id                String   @id @default(cuid())
  exchangeAccountId String   @unique @map("exchange_account_id")
  encryptedKey      String   @map("encrypted_key")
  encryptedSecret   String   @map("encrypted_secret")
  keyVersion        Int      @default(1) @map("key_version")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  exchangeAccount ExchangeAccount @relation(fields: [exchangeAccountId], references: [id], onDelete: Cascade)

  @@map("encrypted_api_keys")
}

model ApiKeyPermission {
  id                String   @id @default(cuid())
  exchangeAccountId String   @map("exchange_account_id")
  canRead           Boolean  @default(true) @map("can_read")
  canTrade          Boolean  @default(false) @map("can_trade")
  canWithdraw       Boolean  @default(false) @map("can_withdraw")
  verifiedAt        DateTime? @map("verified_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  exchangeAccount ExchangeAccount @relation(fields: [exchangeAccountId], references: [id], onDelete: Cascade)

  @@map("api_key_permissions")
}

// ─── Mode State ──────────────────────────────────────────────────────────────

enum TradingMode {
  PAPER
  MANUAL
  AUTO
}

enum AutoState {
  LOCKED
  READY
  PAUSED
  EMERGENCY_STOP
}

model ModeState {
  id                    String      @id @default(cuid())
  userId                String      @unique @map("user_id")
  currentMode           TradingMode @default(PAPER) @map("current_mode")
  paperEnabled          Boolean     @default(true) @map("paper_enabled")
  manualEnabled         Boolean     @default(true) @map("manual_enabled")
  autoVisible           Boolean     @default(true) @map("auto_visible")
  autoSelected          Boolean     @default(false) @map("auto_selected")
  autoExecutionEnabled  Boolean     @default(false) @map("auto_execution_enabled")
  autoBlockedReason     String?     @map("auto_blocked_reason")
  autoState             AutoState   @default(LOCKED) @map("auto_state")
  emergencyPaused       Boolean     @default(false) @map("emergency_paused")
  lastChangedAt         DateTime    @default(now()) @map("last_changed_at")
  lastChangedBy         String?     @map("last_changed_by")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mode_state")
}

// ─── Market Data ─────────────────────────────────────────────────────────────

model Asset {
  id        String   @id @default(cuid())
  symbol    String   @unique
  baseAsset String   @map("base_asset")
  quoteAsset String  @map("quote_asset")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  candles          Candle[]
  marketSnapshots  MarketSnapshot[]
  orderBooks       OrderBook[]
  signals          Signal[]
  shadowTrades     ShadowTrade[]
  tradeCards       TradeCard[]

  @@map("assets")
}

model Venue {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exchangeAccounts ExchangeAccount[]
  marketSnapshots  MarketSnapshot[]
  orderBooks       OrderBook[]
  candles          Candle[]
  orders           Order[]
  fills            Fill[]

  @@map("venues")
}

model MarketSnapshot {
  id        String   @id @default(cuid())
  assetId   String   @map("asset_id")
  venueId   String   @map("venue_id")
  bid       Decimal  @db.Decimal(24, 12)
  ask       Decimal  @db.Decimal(24, 12)
  last      Decimal  @db.Decimal(24, 12)
  volume24h Decimal  @map("volume_24h") @db.Decimal(24, 12)
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])

  @@index([assetId, venueId, timestamp])
  @@map("market_snapshots")
}

model OrderBook {
  id        String   @id @default(cuid())
  assetId   String   @map("asset_id")
  venueId   String   @map("venue_id")
  bids      Json
  asks      Json
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])

  @@index([assetId, venueId, timestamp])
  @@map("order_books")
}

model Candle {
  id        String   @id @default(cuid())
  assetId   String   @map("asset_id")
  venueId   String   @map("venue_id")
  timeframe String
  open      Decimal  @db.Decimal(24, 12)
  high      Decimal  @db.Decimal(24, 12)
  low       Decimal  @db.Decimal(24, 12)
  close     Decimal  @db.Decimal(24, 12)
  volume    Decimal  @db.Decimal(24, 12)
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])

  @@unique([assetId, venueId, timeframe, timestamp])
  @@index([assetId, venueId, timeframe, timestamp])
  @@map("candles")
}

model Feature {
  id          String   @id @default(cuid())
  assetId     String?  @map("asset_id")
  name        String
  version     String
  value       Json
  computedAt  DateTime @map("computed_at")
  dataSource  String   @map("data_source")
  assumptions Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([name, version, computedAt])
  @@map("features")
}

model MarketRegime {
  id          String   @id @default(cuid())
  label       String
  version     String
  confidence  Decimal? @db.Decimal(8, 6)
  features    Json
  detectedAt  DateTime @map("detected_at")
  dataSource  String   @map("data_source")
  assumptions Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([detectedAt])
  @@map("market_regimes")
}

// ─── Strategy Library ────────────────────────────────────────────────────────

model StrategyLibrary {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  category    String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  variants StrategyVariant[]

  @@map("strategy_library")
}

model StrategyVariant {
  id           String   @id @default(cuid())
  libraryId    String   @map("library_id")
  version      String
  name         String
  description  String?
  logicHash    String   @map("logic_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  library            StrategyLibrary          @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  backtests          StrategyBacktest[]
  proofGates         StrategyProofGate[]
  performance        StrategyPerformance[]
  forwardTests       StrategyForwardTest[]
  liveCanaries       StrategyLiveCanary[]
  parameterSets      ParameterSet[]
  signals            Signal[]
  shadowTrades       ShadowTrade[]
  tradeCards         TradeCard[]
  promotionEvents    StrategyPromotionEvent[]
  demotionEvents     StrategyDemotionEvent[]
  cooldownEvents     StrategyCooldownEvent[]

  @@unique([libraryId, version])
  @@index([libraryId, version])
  @@map("strategy_variants")
}

model StrategyBacktest {
  id               String   @id @default(cuid())
  variantId        String   @map("variant_id")
  version          String
  dataSource       String   @map("data_source")
  timeframe        String
  startDate        DateTime @map("start_date")
  endDate          DateTime @map("end_date")
  assumptions      Json
  feeModel         Json     @map("fee_model")
  slippageModel    Json     @map("slippage_model")
  results          Json
  netProfit        Decimal? @map("net_profit") @db.Decimal(24, 12)
  expectancy       Decimal? @db.Decimal(24, 12)
  maxDrawdown      Decimal? @map("max_drawdown") @db.Decimal(24, 12)
  status           String
  createdAt        DateTime @default(now()) @map("created_at")

  variant StrategyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, createdAt])
  @@map("strategy_backtests")
}

model StrategyProofGate {
  id          String    @id @default(cuid())
  variantId   String    @map("variant_id")
  gateName    String    @map("gate_name")
  gateVersion String    @map("gate_version")
  status      String
  reasonCode  String?   @map("reason_code")
  evidence    Json?
  evaluatedAt DateTime  @map("evaluated_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  variant StrategyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, gateName])
  @@map("strategy_proof_gates")
}

model StrategyPerformance {
  id              String   @id @default(cuid())
  variantId       String   @map("variant_id")
  period          String
  dataSource      String   @map("data_source")
  netProfit       Decimal  @map("net_profit") @db.Decimal(24, 12)
  grossProfit     Decimal  @map("gross_profit") @db.Decimal(24, 12)
  fees            Decimal  @db.Decimal(24, 12)
  slippage        Decimal  @db.Decimal(24, 12)
  winRate         Decimal? @map("win_rate") @db.Decimal(8, 6)
  expectancy      Decimal? @db.Decimal(24, 12)
  sharpeRatio     Decimal? @map("sharpe_ratio") @db.Decimal(12, 6)
  maxDrawdown     Decimal? @map("max_drawdown") @db.Decimal(24, 12)
  tradeCount      Int      @map("trade_count")
  assumptions     Json
  calculatedAt    DateTime @map("calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  variant StrategyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, period])
  @@map("strategy_performance")
}

model StrategyForwardTest {
  id           String   @id @default(cuid())
  variantId    String   @map("variant_id")
  startDate    DateTime @map("start_date")
  endDate      DateTime? @map("end_date")
  dataSource   String   @map("data_source")
  assumptions  Json
  feeModel     Json     @map("fee_model")
  slippageModel Json    @map("slippage_model")
  results      Json
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  variant StrategyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("strategy_forward_tests")
}

model StrategyLiveCanary {
  id           String    @id @default(cuid())
  variantId    String    @map("variant_id")
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  maxSize      Decimal   @map("max_size") @db.Decimal(24, 12)
  status       String
  results      Json?
  createdAt    DateTime  @default(now()) @map("created_at")

  variant StrategyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("strategy_live_canaries")
}

model ParameterSet {
  id          String   @id @default(cuid())
  variantId   String   @map("variant_id")
  version     String
  parameters  Json
  logicHash   String   @map("logic_hash")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by")
  reversible  Boolean  @default(true)

  variant      StrategyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  tests        ParameterTest[]

  @@unique([variantId, version])
  @@map("parameter_sets")
}

model ParameterTest {
  id              String   @id @default(cuid())
  parameterSetId  String   @map("parameter_set_id")
  testType        String   @map("test_type")
  dataSource      String   @map("data_source")
  assumptions     Json
  feeModel        Json     @map("fee_model")
  slippageModel   Json     @map("slippage_model")
  results         Json
  status          String
  createdAt       DateTime @default(now()) @map("created_at")

  parameterSet ParameterSet @relation(fields: [parameterSetId], references: [id], onDelete: Cascade)

  @@map("parameter_tests")
}

// ─── Research & Alpha ────────────────────────────────────────────────────────

model AlphaResearchResult {
  id           String   @id @default(cuid())
  name         String
  version      String
  dataSource   String   @map("data_source")
  timeframe    String
  assumptions  Json
  feeModel     Json     @map("fee_model")
  slippageModel Json    @map("slippage_model")
  results      Json
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([name, version])
  @@map("alpha_research_results")
}

model EdgeDiscoveryRun {
  id          String   @id @default(cuid())
  name        String
  version     String
  dataSource  String   @map("data_source")
  assumptions Json
  results     Json
  status      String
  startedAt   DateTime @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("edge_discovery_runs")
}

model BenchmarkAlphaResult {
  id           String   @id @default(cuid())
  strategyRef  String   @map("strategy_ref")
  benchmarkRef String   @map("benchmark_ref")
  dataSource   String   @map("data_source")
  timeframe    String
  alpha        Decimal? @db.Decimal(24, 12)
  beta         Decimal? @db.Decimal(12, 6)
  assumptions  Json
  calculatedAt DateTime @map("calculated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("benchmark_alpha_results")
}

model MonteCarloTest {
  id           String   @id @default(cuid())
  strategyRef  String   @map("strategy_ref")
  iterations   Int
  dataSource   String   @map("data_source")
  assumptions  Json
  feeModel     Json     @map("fee_model")
  slippageModel Json    @map("slippage_model")
  results      Json
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("monte_carlo_tests")
}

model WalkForwardTest {
  id           String   @id @default(cuid())
  strategyRef  String   @map("strategy_ref")
  folds        Int
  dataSource   String   @map("data_source")
  assumptions  Json
  feeModel     Json     @map("fee_model")
  slippageModel Json    @map("slippage_model")
  results      Json
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("walk_forward_tests")
}

model AdversarialMarketTest {
  id           String   @id @default(cuid())
  strategyRef  String   @map("strategy_ref")
  scenario     String
  dataSource   String   @map("data_source")
  assumptions  Json
  results      Json
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("adversarial_market_tests")
}

model MarketMicrostructureTest {
  id           String   @id @default(cuid())
  strategyRef  String   @map("strategy_ref")
  venueRef     String   @map("venue_ref")
  dataSource   String   @map("data_source")
  assumptions  Json
  results      Json
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("market_microstructure_tests")
}

// ─── Signals & Trades ────────────────────────────────────────────────────────

model Signal {
  id          String   @id @default(cuid())
  variantId   String   @map("variant_id")
  assetId     String   @map("asset_id")
  direction   String
  strength    Decimal? @db.Decimal(8, 6)
  reasonCodes Json     @map("reason_codes")
  metadata    Json?
  generatedAt DateTime @map("generated_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  variant StrategyVariant @relation(fields: [variantId], references: [id])
  asset   Asset           @relation(fields: [assetId], references: [id])

  @@index([variantId, generatedAt])
  @@map("signals")
}

model ShadowTrade {
  id           String   @id @default(cuid())
  variantId    String   @map("variant_id")
  assetId      String   @map("asset_id")
  direction    String
  entryPrice   Decimal  @map("entry_price") @db.Decimal(24, 12)
  exitPrice    Decimal? @map("exit_price") @db.Decimal(24, 12)
  size         Decimal  @db.Decimal(24, 12)
  status       String
  assumptions  Json
  feeModel     Json     @map("fee_model")
  slippageModel Json    @map("slippage_model")
  pnl          Decimal? @db.Decimal(24, 12)
  reasonCodes  Json     @map("reason_codes")
  openedAt     DateTime @map("opened_at")
  closedAt     DateTime? @map("closed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  variant StrategyVariant @relation(fields: [variantId], references: [id])
  asset   Asset           @relation(fields: [assetId], references: [id])

  @@map("shadow_trades")
}

// ─── Paper-Forward Evidence ──────────────────────────────────────────────────

enum PaperTradeSide {
  LONG
  SHORT
  NO_TRADE
}

enum PaperTradeStatus {
  OPEN
  CLOSED
  EXPIRED
  CANCELLED
  NO_TRADE
}

enum PaperTradeResult {
  WIN
  LOSS
  BREAKEVEN
  OPEN
  NO_TRADE
}

model PaperEvidenceRun {
  id                      String    @id @default(cuid())
  userId                  String    @map("user_id")
  status                  String
  symbols                 String[]
  marketDataReady         Boolean   @default(false) @map("market_data_ready")
  actions                 Json      @default("[]")
  errorCount              Int       @default(0) @map("error_count")
  universeSize            Int?      @map("universe_size")
  scannedSymbolCount      Int?      @map("scanned_symbol_count")
  rankedCandidateCount    Int?      @map("ranked_candidate_count")
  evaluatedCandidateCount Int?      @map("evaluated_candidate_count")
  tradesOpened            Int?      @map("trades_opened")
  tradesUpdated           Int?      @map("trades_updated")
  tradesClosed            Int?      @map("trades_closed")
  noTradeCount            Int?      @map("no_trade_count")
  successfulFetches       Int?      @map("successful_fetches")
  failedFetches           Int?      @map("failed_fetches")
  averageSpreadBps        Decimal?  @map("average_spread_bps") @db.Decimal(12, 6)
  staleSymbolCount        Int?      @map("stale_symbol_count")
  scanSummary             Json?     @map("scan_summary")
  scannerMode             String?   @map("scanner_mode")
  dataSources             String[]  @default([]) @map("data_sources")
  coinsDiscovered         Int?      @map("coins_discovered")
  coinsEvaluated          Int?      @map("coins_evaluated")
  watchlistCount          Int?      @map("watchlist_count")
  highVolCount            Int?      @map("high_vol_count")
  reasonCode              String?   @map("reason_code")
  reasonText              String?   @map("reason_text")
  candidatesStored        Int       @default(0) @map("candidates_stored")
  signalsStored           Int       @default(0) @map("signals_stored")
  snapshotsStored         Int       @default(0) @map("snapshots_stored")
  maxOpenTrades           Int?      @map("max_open_trades")
  maxOpenTradesReached    Boolean   @default(false) @map("max_open_trades_reached")
  missedOpportunitiesStored Int?    @map("missed_opportunities_stored")
  rotationsPerformed      Int?      @map("rotations_performed")
  runWarnings             Json      @default("[]") @map("run_warnings")
  runErrors               Json      @default("[]") @map("run_errors")
  startedAt               DateTime  @map("started_at")
  completedAt             DateTime? @map("completed_at")
  createdAt               DateTime  @default(now()) @map("created_at")

  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signals             PaperSignal[]
  candidates          PaperScanCandidate[]
  missedOpportunities PaperMissedOpportunity[]
  rotationEvents      PaperRotationEvent[]

  @@index([userId, startedAt])
  @@map("paper_evidence_runs")
}

model PaperSignal {
  id           String         @id @default(cuid())
  runId        String         @map("run_id")
  userId       String         @map("user_id")
  symbol       String
  side         PaperTradeSide
  strategyName String         @map("strategy_name")
  confidence   Decimal?       @db.Decimal(8, 6)
  reason       String
  noTrade      Boolean        @default(false) @map("no_trade")
  marketPrice  Decimal?       @map("market_price") @db.Decimal(24, 12)
  createdAt    DateTime       @default(now()) @map("created_at")

  run   PaperEvidenceRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade PaperTrade?

  @@index([runId])
  @@index([userId, createdAt])
  @@map("paper_signals")
}

model PaperTrade {
  id                String           @id @default(cuid())
  userId            String           @map("user_id")
  signalId          String?          @unique @map("signal_id")
  symbol            String
  baseAsset         String           @map("base_asset")
  quoteAsset        String           @map("quote_asset")
  side              PaperTradeSide
  strategyName      String           @map("strategy_name")
  entryPrice        Decimal?         @map("entry_price") @db.Decimal(24, 12)
  plannedStopLoss   Decimal?         @map("planned_stop_loss") @db.Decimal(24, 12)
  plannedTakeProfit Decimal?         @map("planned_take_profit") @db.Decimal(24, 12)
  simulatedSize     Decimal?         @map("simulated_size") @db.Decimal(24, 12)
  riskAmount        Decimal?         @map("risk_amount") @db.Decimal(24, 12)
  riskPercent       Decimal?         @map("risk_percent") @db.Decimal(8, 6)
  status            PaperTradeStatus
  openedAt          DateTime?        @map("opened_at")
  closedAt          DateTime?        @map("closed_at")
  exitPrice         Decimal?         @map("exit_price") @db.Decimal(24, 12)
  grossPaperPnl     Decimal?         @map("gross_paper_pnl") @db.Decimal(24, 12)
  estimatedFees     Decimal?         @map("estimated_fees") @db.Decimal(24, 12)
  estimatedSlippage Decimal?         @map("estimated_slippage") @db.Decimal(24, 12)
  netPaperPnl       Decimal?         @map("net_paper_pnl") @db.Decimal(24, 12)
  result            PaperTradeResult
  confidence        Decimal?         @db.Decimal(8, 6)
  reason            String
  dataSource        String           @default("kraken") @map("data_source")
  isRealTrade       Boolean          @default(false) @map("is_real_trade")
  isVerifiedLivePnl Boolean          @default(false) @map("is_verified_live_pnl")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal    PaperSignal?         @relation(fields: [signalId], references: [id])
  snapshots PaperTradeSnapshot[]

  @@index([userId, status])
  @@index([userId, openedAt])
  @@map("paper_forward_trades")
}

model PaperTradeSnapshot {
  id            String   @id @default(cuid())
  tradeId       String   @map("trade_id")
  markPrice     Decimal  @map("mark_price") @db.Decimal(24, 12)
  unrealizedPnl Decimal? @map("unrealized_pnl") @db.Decimal(24, 12)
