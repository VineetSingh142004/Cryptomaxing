  DEX_SCREENER
  GECKOTERMINAL
  DEFILLAMA
  LUNARCRUSH
  GOPLUS
}

enum EncryptionMethod {
  DEV_AES256_GCM
  AES256_GCM
}

enum ProviderKeyStatus {
  ACTIVE
  DISABLED
  EMERGENCY_DISABLED
  BLOCKED_WITHDRAWAL
  PERMISSION_UNKNOWN
}

model ProviderCredential {
  id                      String            @id @default(cuid())
  userId                  String            @map("user_id")
  provider                ProviderType
  label                   String
  encryptedKey            String            @map("encrypted_key")
  encryptedSecret         String?           @map("encrypted_secret")
  encryptedPassphrase     String?           @map("encrypted_passphrase")
  keyVersion              Int               @default(1) @map("key_version")
  encryptionMethod        EncryptionMethod  @default(DEV_AES256_GCM) @map("encryption_method")
  status                  ProviderKeyStatus @default(ACTIVE)
  disabledReason          String?           @map("disabled_reason")
  ipWhitelistRecommended  Boolean           @default(true) @map("ip_whitelist_recommended")
  ipWhitelistConfigured   Boolean           @default(false) @map("ip_whitelist_configured")
  permissionsMetadata     Json?             @map("permissions_metadata")
  canRead                 Boolean           @default(true) @map("can_read")
  canTrade                Boolean           @default(false) @map("can_trade")
  canWithdraw             Boolean           @default(false) @map("can_withdraw")
  permissionDetected      Boolean           @default(false) @map("permission_detected")
  permissionReasonCode    String?           @map("permission_reason_code")
  lastConnectionTestAt    DateTime?         @map("last_connection_test_at")
  lastConnectionStatus    String?           @map("last_connection_status")
  lastHealthCheckAt       DateTime?         @map("last_health_check_at")
  lastHealthStatus        String?           @map("last_health_status")
  lastLatencyMs           Int?              @map("last_latency_ms")
  permissionSelfAttestation Json?           @map("permission_self_attestation")
  lastReadOnlyVerifiedAt  DateTime?         @map("last_readonly_verified_at")
  readonlyVerificationResult Json?          @map("readonly_verification_result")
  lastKrakenNonce         String?           @map("last_kraken_nonce")
  disabledAt              DateTime?         @map("disabled_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthLogs  ProviderHealthLog[]

  @@index([userId, provider])
  @@index([status])
  @@map("provider_credentials")
}

model ProviderHealthLog {
  id           String   @id @default(cuid())
  credentialId String   @map("credential_id")
  status       String
  latencyMs    Int?     @map("latency_ms")
  reasonCode   String?  @map("reason_code")
  detail       Json?
  checkedAt    DateTime @map("checked_at")
  createdAt    DateTime @default(now()) @map("created_at")

  credential ProviderCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, checkedAt])
  @@map("provider_health_logs")
}
